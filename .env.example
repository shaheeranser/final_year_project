# Application Configuration
PORT=3000
NODE_ENV=production

# MongoDB Configuration
MONGO_URI=mongodb://mongo:27017/incident_db

# MinIO Configuration
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=incident-snapshots

# Moodle Database Configuration (For bitnami/postgresql and bitnami/moodle)
MOODLE_DATABASE_HOST=moodle-db
MOODLE_DATABASE_PORT_NUMBER=5432
MOODLE_DATABASE_USER=bn_moodle
MOODLE_DATABASE_PASSWORD=bitnami
MOODLE_DATABASE_NAME=bitnami_moodle

# PostgreSQL specific variables for initialization (bitnami/postgresql)
POSTGRESQL_USERNAME=bn_moodle
POSTGRESQL_PASSWORD=bitnami
POSTGRESQL_DATABASE=bitnami_moodle

# Moodle Site Configuration
MOODLE_PASSWORD=bitnami

# LTI 1.3 / ltijs Configuration
# Random encryption key used by ltijs to encrypt/decrypt stored platform data.
# Generate your own with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LTI_ENCRYPTION_KEY=CHANGE_ME_random_placeholder_abc123

# LTI Platform Registration
# These values are filled in AFTER manually registering this tool inside
# Moodle's admin UI (Site admin -> Plugins -> External tool -> Manage tools).
# Leave empty until then — the server will start but skip platform registration.

# Moodle's issuer URL (e.g. http://localhost:8000)
PLATFORM_URL=
# Client ID generated by Moodle when you register the external tool
PLATFORM_CLIENT_ID=
# Moodle's OIDC authorization endpoint (e.g. http://localhost:8000/mod/lti/auth.php)
PLATFORM_AUTH_ENDPOINT=
# Moodle's OAuth2 access-token endpoint (e.g. http://localhost:8000/mod/lti/token.php)
PLATFORM_TOKEN_ENDPOINT=
# Moodle's public keyset URL (e.g. http://localhost:8000/mod/lti/certs.php)
PLATFORM_KEYSET_ENDPOINT=
